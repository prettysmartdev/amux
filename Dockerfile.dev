FROM node:22-slim

# ── System packages ──────────────────────────────────────────────────
# make          – build orchestration (Makefile: make all / test / install)
# git           – version control (localdev.md)
# build-essential, pkg-config, musl-tools – compile Rust crates + musl static linking
# curl, ca-certificates – fetch installers (rustup, Docker CLI GPG key)
RUN apt-get update && apt-get install -y --no-install-recommends \
        make \
        git \
        build-essential \
        pkg-config \
        musl-tools \
        curl \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# ── Docker CLI ───────────────────────────────────────────────────────
# aspec launches containers via the local Docker daemon (design.md, security.md).
# Only the CLI is needed; the daemon is provided by the host via a mounted socket.
RUN install -m 0755 -d /etc/apt/keyrings \
    && curl -fsSL https://download.docker.com/linux/debian/gpg -o /etc/apt/keyrings/docker.asc \
    && chmod a+r /etc/apt/keyrings/docker.asc \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.asc] \
       https://download.docker.com/linux/debian $(. /etc/os-release && echo "$VERSION_CODENAME") stable" \
       > /etc/apt/sources.list.d/docker.list \
    && apt-get update && apt-get install -y --no-install-recommends docker-ce-cli \
    && rm -rf /var/lib/apt/lists/*

# ── Rust toolchain ───────────────────────────────────────────────────
# Rust stable with the musl target for producing a single statically-linked binary
# (foundation.md, design.md). Edition 2021 / Cargo for build & test.
ENV RUSTUP_HOME=/usr/local/rustup \
    CARGO_HOME=/usr/local/cargo \
    PATH="/usr/local/cargo/bin:${PATH}"

RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs \
    | sh -s -- -y --default-toolchain stable --profile minimal \
    && rustup target add x86_64-unknown-linux-musl \
    && rustc --version && cargo --version

# ── Claude Code ──────────────────────────────────────────────────────
RUN npm install -g @anthropic-ai/claude-code

WORKDIR /workspace
