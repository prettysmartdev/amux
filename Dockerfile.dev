FROM debian:bookworm-20250317-slim

# Pin Rust toolchain version — must match rust-toolchain.toml and Cargo.toml rust-version
ENV RUST_VERSION=1.94.0
ENV RUSTUP_HOME=/usr/local/rustup
ENV CARGO_HOME=/usr/local/cargo
ENV PATH="/usr/local/cargo/bin:${PATH}"

# Install system packages required for building and testing the project:
#   git            - version control (repo interaction)
#   ca-certificates - TLS root certs for HTTPS fetches
#   curl           - downloading installers (rustup, claude)
#   make           - build orchestration (make all / make test / make install)
#   gcc            - C linker required by cargo/rustc
#   libc6-dev      - C headers and libs for linking
#   pkg-config     - locating system libraries during cargo build
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    ca-certificates \
    curl \
    make \
    gcc \
    libc6-dev \
    pkg-config \
    && rm -rf /var/lib/apt/lists/*

# Install Rust toolchain via rustup, pinned to a specific stable version
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | \
    sh -s -- -y --default-toolchain "${RUST_VERSION}" --profile minimal \
    && rustc --version \
    && cargo --version

# Install Claude Code via official standalone installer
RUN curl -fsSL https://claude.ai/install.sh | bash \
    && cp /root/.local/bin/claude /usr/local/bin/claude

WORKDIR /workspace
