FROM debian:bookworm-slim

# System packages required for building, testing, and running the project
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    ca-certificates \
    curl \
    make \
    gcc \
    libc6-dev \
    pkg-config \
    && rm -rf /var/lib/apt/lists/*

# Install Rust toolchain pinned to the version declared in Cargo.toml (rust-version)
ENV RUSTUP_HOME=/usr/local/rustup \
    CARGO_HOME=/usr/local/cargo \
    PATH="/usr/local/cargo/bin:${PATH}"
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | \
    sh -s -- -y --default-toolchain 1.94.0 --profile minimal \
    && rustc --version && cargo --version

# Install Docker CLI (pinned version) so the container can interact with the host Docker daemon
ENV DOCKER_VERSION=27.5.1
RUN curl -fsSL "https://download.docker.com/linux/static/stable/$(uname -m)/docker-${DOCKER_VERSION}.tgz" \
    | tar xz --strip-components=1 -C /usr/local/bin docker/docker \
    && docker --version

# Install Claude Code via official standalone installer
RUN curl -fsSL https://claude.ai/install.sh | bash \
    && cp /root/.local/bin/claude /usr/local/bin/claude

# Create non-root user and set up workspace
RUN useradd -m -s /bin/bash amux \
    && mkdir -p /workspace \
    && chown amux:amux /workspace

USER amux
WORKDIR /workspace
